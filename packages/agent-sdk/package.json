{
  "name": "@ferax564/noma-agent-sdk",
  "version": "0.1.3",
  "description": "Reference agent SDK for the Noma Agent Protocol v1.0 (experimental)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferax564/noma.git",
    "directory": "packages/agent-sdk"
  },
  "homepage": "https://ferax564.github.io/noma/docs/agent-guide.html",
  "bugs": {
    "url": "https://github.com/ferax564/noma/issues"
  },
  "files": ["src", "dist", "README.md"],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "pretest": "cd ../.. && npm run build -w @ferax564/noma-mcp-server && npm run demo:stale-memo && npm run demo:agent-memory",
    "test": "tsx --test test/*.test.ts",
    "demo:agent-stale-memo": "tsx scripts/agent-stale-memo-sdk.ts",
    "demo:agent-memory": "tsx scripts/agent-memory-demo-sdk.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@ferax564/noma-cli": "0.14.0",
    "@ferax564/noma-mcp-server": "0.13.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": { "node": ">=20" },
  "author": "ferax564",
  "license": "MIT"
}
