{
  "name": "@ferax564/noma-mcp-server",
  "version": "0.13.0",
  "description": "MCP server for @ferax564/noma-cli — block-level agent editing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "ferax564",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferax564/noma.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://ferax564.github.io/noma/",
  "bugs": {
    "url": "https://github.com/ferax564/noma/issues"
  },
  "bin": {
    "noma-mcp-server": "dist/index.js"
  },
  "files": ["src", "dist", "README.md"],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@ferax564/noma-cli": "0.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
