{
  "name": "noma-language",
  "displayName": "Noma",
  "description": "Syntax highlighting for the Noma document format (.noma) — directives, blocks, frontmatter, math, wikilinks, embedded JSON/LaTeX/Mermaid/DOT.",
  "version": "0.2.0",
  "publisher": "ferax564",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "noma",
    "documents",
    "agents",
    "research",
    "markdown-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ferax564/noma.git",
    "directory": "tools/vscode-noma"
  },
  "homepage": "https://ferax564.github.io/noma/",
  "bugs": {
    "url": "https://github.com/ferax564/noma/issues"
  },
  "galleryBanner": {
    "color": "#0b132b",
    "theme": "dark"
  },
  "//icon": "intentionally omitted in v0.2.0 — no asset to ship. Add in v0.3.0 with a 128x128 PNG.",
  "contributes": {
    "languages": [
      {
        "id": "noma",
        "aliases": ["Noma", "noma"],
        "extensions": [".noma"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "noma",
        "scopeName": "source.noma",
        "path": "./syntaxes/noma.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.frontmatter": "yaml",
          "meta.embedded.block.math": "latex",
          "meta.embedded.block.plotly": "json",
          "meta.embedded.block.diagram.mermaid": "mermaid",
          "meta.embedded.block.diagram.graphviz": "dot"
        }
      }
    ]
  }
}
