{
  "name": "noma-language",
  "displayName": "Noma",
  "description": "Language support for the Noma document format (.noma) — syntax highlighting plus diagnostics, outline, go-to-definition, and wikilink completion via the Noma language server.",
  "version": "0.3.0",
  "publisher": "ferax564",
  "license": "MIT",
  "main": "./client.js",
  "engines": {
    "vscode": "^1.82.0"
  },
  "activationEvents": [
    "onLanguage:noma"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "noma",
    "documents",
    "agents",
    "research",
    "markdown-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ferax564/noma.git",
    "directory": "tools/vscode-noma"
  },
  "homepage": "https://ferax564.github.io/noma/",
  "bugs": {
    "url": "https://github.com/ferax564/noma/issues"
  },
  "galleryBanner": {
    "color": "#0b132b",
    "theme": "dark"
  },
  "//icon": "intentionally omitted in v0.2.0 — no asset to ship. Add in v0.3.0 with a 128x128 PNG.",
  "contributes": {
    "configuration": {
      "title": "Noma",
      "properties": {
        "noma.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Command used to launch the Noma language server (split on whitespace). Empty runs `npx -y @ferax564/noma-lsp`."
        }
      }
    },
    "languages": [
      {
        "id": "noma",
        "aliases": ["Noma", "noma"],
        "extensions": [".noma"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "noma",
        "scopeName": "source.noma",
        "path": "./syntaxes/noma.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.frontmatter": "yaml",
          "meta.embedded.block.math": "latex",
          "meta.embedded.block.plotly": "json",
          "meta.embedded.block.diagram.mermaid": "mermaid",
          "meta.embedded.block.diagram.graphviz": "dot"
        }
      }
    ]
  }
}
