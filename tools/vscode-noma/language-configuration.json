{
  "comments": {
    "blockComment": ["::comment", "::"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "`", "close": "`" },
    { "open": "**", "close": "**" },
    { "open": "$", "close": "$", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["`", "`"],
    ["*", "*"],
    ["**", "**"],
    ["$", "$"]
  ],
  "folding": {
    "markers": {
      "start": "^::+[a-z_][a-z0-9_]*",
      "end": "^::+\\s*$"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d+)|([\\w\\-]+)",
  "indentationRules": {
    "increaseIndentPattern": "^::+[a-z_][a-z0-9_]*(\\{[^}]*\\})?\\s*$",
    "decreaseIndentPattern": "^::+\\s*$"
  }
}
